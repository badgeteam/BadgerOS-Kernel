[submodule "kernel/lib/opensbi"]
	path = kernel/lib/opensbi
	url = https://github.com/riscv-software-src/opensbi
[submodule "kernel/lib/u-boot"]
	path = kernel/lib/u-boot
	url = https://github.com/u-boot/u-boot
[submodule "kernel/lib/uacpi"]
	path = kernel/lib/uacpi
	url = https://github.com/ultraos/uacpi
[submodule "kernel/lib/nanoprintf"]
	path = kernel/lib/nanoprintf
	url = https://github.com/charlesnicholson/nanoprintf
[submodule "kernel/lib/limine"]
	path = kernel/lib/limine
	url = https://codeberg.org/Limine/Limine.git
